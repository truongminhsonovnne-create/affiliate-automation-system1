# ============================================
# Affiliate Automation System - Environment Variables Template
# ============================================
#
# HOW TO USE:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in all REQUIRED values with real credentials
# 3. NEVER commit .env with real secrets to version control
#
# ENVIRONMENTS:
#   development  - local dev (all services on localhost)
#   test         - CI/test runs
#   production   - live deployment
#
# ============================================

# ============================================
# REQUIRED: Application Core
# ============================================

NODE_ENV=development

# ============================================
# REQUIRED: Shopee Integration
# ============================================

# Path to browser user data directory (for session persistence)
# IMPORTANT: This directory contains cookies/session data - never commit it
SHOPEE_USER_DATA_DIR=./shopee-data

# Shopee base URL (do not change unless using a mirror)
SHOPEE_BASE_URL=https://shopee.vn

# Mobile user agent for Shopee mobile version
# Get yours from: https://www.whatismybrowser.com/detect/what-is-my-user-agent
SHOPEE_MOBILE_USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Mobile/15E148 Safari/604.1

# ============================================
# REQUIRED: AI Service
# ============================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API Key (optional - for faster inference with Groq models)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# AI model to use (gemini-2.0-flash, gemini-2.0-flash-lite, gemini-1.5-flash, etc.)
GEMINI_MODEL=gemini-2.0-flash

# ============================================
# REQUIRED: Database (Supabase)
# ============================================

# Your Supabase project URL (from Project Settings > API)
# Format: https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Service role key - has full database access (admin privileges)
# KEEP THIS SECRET! Never expose in client-side code.
# Get from: Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# REQUIRED: Admin Dashboard Authentication
# ============================================

# Username for admin dashboard login
ADMIN_USERNAME=admin

# PRODUCTION: bcrypt hash of the admin password (RECOMMENDED)
# Generate a hash:
#   node -e "const b = require('bcryptjs'); b.hash('your-password', 12).then(h => console.log(h))"
# Set this in production. NEVER set ADMIN_PASSWORD below in production.
ADMIN_PASSWORD_HASH=your-bcrypt-hash-here

# DEVELOPMENT ONLY: plain-text password (dev/test only, auto-hashed at startup)
# DO NOT use in production. If ADMIN_PASSWORD_HASH is set, this is ignored.
# Generate a strong password: openssl rand -base64 24 | tr -d '/+=' | head -c 20
ADMIN_PASSWORD=dev-only-password-please-change

# Session version (increment to revoke all active sessions)
# Change this value to force all users to re-login immediately
SESSION_VERSION=1

# ============================================
# REQUIRED: Session Security
# ============================================

# Secret for signing session cookies (minimum 32 characters)
# Generate: openssl rand -hex 32
SESSION_SECRET=your-session-secret-min-32-random-chars-here

# ============================================
# REQUIRED: Control Plane Security
# ============================================

# Internal secret for admin-to-control-plane API authentication (minimum 16 characters)
# Must match between admin dashboard and control plane service.
# Generate: openssl rand -hex 32
CONTROL_PLANE_INTERNAL_SECRET=your-internal-secret-min-16-chars-here

# ============================================
# REQUIRED: Experiment Privacy
# ============================================

# Random salt for hashing experiment subject identifiers (minimum 16 characters)
# Generate: openssl rand -hex 32
EXPERIMENT_SALT=your-experiment-salt-min-16-random-chars-here

# ============================================
# OPTIONAL: Internal API Network
# ============================================

# URL of the control plane/internal API (for admin dashboard proxy)
# Default: http://localhost:3001 (development)
# Change for staging/production to your deployed control plane URL
INTERNAL_API_URL=http://localhost:3001

# ============================================
# OPTIONAL: Logging
# ============================================

# Log level: trace, debug, info, warn, error, fatal
# Production recommendation: warn
LOG_LEVEL=info

# ============================================
# OPTIONAL: Browser / Crawler Settings
# ============================================

# Run browser in headless mode (true for CI/production, false for debugging)
BROWSER_HEADLESS=false

# Browser action timeout in milliseconds
BROWSER_TIMEOUT=30000

# Maximum retry attempts for failed crawl operations
CRAWLER_MAX_RETRIES=3

# Delay between crawl actions (milliseconds)
CRAWLER_DELAY_MIN=1000
CRAWLER_DELAY_MAX=3000

# ============================================
# OPTIONAL: AI Enrichment Settings
# ============================================

# Number of products to send to AI for analysis per batch
AI_ANALYSIS_BATCH_SIZE=10

# Minimum confidence score (0-1) for AI analysis to be accepted
AI_CONFIDENCE_THRESHOLD=0.7

# ============================================
# OPTIONAL: Rate Limiting (Production)
# ============================================

# Use Redis for rate limiting (production recommended)
# Dev: false (uses in-memory store)
# Prod: true (requires REDIS_URL below)
USE_REDIS_RATE_LIMIT=false

# Redis connection URL (when USE_REDIS_RATE_LIMIT=true)
# Format: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED: Voucher Engine Persistence
# ──────────────────────────────────────────────────────────────────────────────

# Voucher engine: dedicated Redis connection for resolution result storage.
# Reuses REDIS_URL if not set.
# Separate connection is recommended to isolate TTL namespaces.
# Production: use a dedicated Redis instance with --save policy.
VOUCHER_REDIS_URL=redis://localhost:6379

# ============================================
# OPTIONAL: Proxy / Network
# ============================================

# ============================================
# REQUIRED: GitHub Actions Sync Scheduler
# ============================================

# Secret shared between GitHub Actions workflow and the sync endpoint.
# Must match the SYNC_SHARED_SECRET GitHub Secret.
# Generate: openssl rand -hex 32
SYNC_SHARED_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ============================================
# REQUIRED: AccessTrade Publisher Integration
# ============================================

# AccessTrade API key — your publisher token from the AccessTrade dashboard
# Docs: https://docs.accesstrade.vn/
# SECURITY: This is a server-side secret. NEVER expose to the browser.
ACCESSTRADE_API_KEY=your_accesstrade_api_key_here

# Optional: Override the AccessTrade API base URL
# Default: https://api.accesstrade.vn  (change only if using a regional proxy)
ACCESSTRADE_BASE_URL=https://api.accesstrade.vn

# Optional: Request timeout in milliseconds
# ACCESSTRADE_TIMEOUT_MS=15000

# Optional: Max retries for transient API errors (default: 3)
# ACCESSTRADE_MAX_RETRIES=3

# ============================================
# MASOFFER PUBLISHER API
# ============================================

# MasOffer Publisher ID (required)
MASOFFER_PUBLISHER_ID=your_masoffer_publisher_id_here

# MasOffer API Token (server-side secret — NEVER expose to the browser)
MASOFFER_API_TOKEN=your_masoffer_api_token_here

# Optional: Override the MasOffer API base URL
# Default: https://publisher-api.masoffer.net
# MASOFFER_BASE_URL=https://publisher-api.masoffer.net

# Optional: Request timeout in milliseconds
# MASOFFER_TIMEOUT_MS=15000

# Optional: Max retries for transient API errors (default: 3)
# MASOFFER_MAX_RETRIES=3

# ============================================
# OPTIONAL: Proxy / Network
# ============================================

# Trust reverse proxy headers (enable only behind a reverse proxy/load balancer)
# Default: false (safe - do not enable for direct internet exposure)
TRUST_PROXY=false

# Comma-separated list of trusted proxy IP addresses/CIDRs
# Only used when TRUST_PROXY=true
TRUSTED_PROXY_IPS=127.0.0.1,::1

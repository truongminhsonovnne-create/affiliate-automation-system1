# ============================================
# Affiliate Automation System - Environment Variables
# ============================================

# ============================================
# Shopee Configuration (REQUIRED)
# ============================================

# Path to browser user data directory (for login session persistence)
# Example: ./shopee-data or C:\Users\You\AppData\Local\ShopeeBrowser
SHOPEE_USER_DATA_DIR=./shopee-data

# Shopee base URL
SHOPEE_BASE_URL=https://shopee.vn

# Mobile user agent for Shopee mobile version
# Get from: https://www.whatismybrowser.com/detect/what-is-my-user-agent
SHOPEE_MOBILE_USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Mobile/15E148 Safari/604.1

# ============================================
# Google Gemini AI Configuration (REQUIRED)
# ============================================

# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Model to use (gemini-2.0-flash, gemini-pro, etc.)
GEMINI_MODEL=gemini-2.0-flash

# ============================================
# Supabase Configuration (REQUIRED)
# ============================================

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Service role key (has admin privileges - keep secret!)
# Get from: Supabase Dashboard -> Settings -> API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Application Configuration (Optional)
# ============================================

# Node environment
NODE_ENV=development

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# Browser settings
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000

# Crawler settings
CRAWLER_MAX_RETRIES=3
CRAWLER_DELAY_MIN=1000
CRAWLER_DELAY_MAX=3000

# AI settings
AI_ANALYSIS_BATCH_SIZE=10
AI_CONFIDENCE_THRESHOLD=0.7

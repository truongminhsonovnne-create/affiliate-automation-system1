# ============================================================
# VoucherFinder — Production Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Docker / CI: set these as real environment variables
# in your docker-compose.yml, .env.production, or hosting
# platform dashboard.
#
# NEVER commit .env.local or .env.production to git.
# ============================================================

# ------------------------------------------------------------------
# 1. PUBLIC — safe to expose to the browser
# ------------------------------------------------------------------

# Canonical base URL of this deployment (no trailing slash)
# Used for: sitemap, canonical tags, OG/Twitter images, metadataBase
NEXT_PUBLIC_SITE_URL=https://voucherfinder.app

# Contact email shown in footer, contact page, and legal pages.
# This is public-facing — change to your real email address.
NEXT_PUBLIC_CONTACT_EMAIL=lienhe@voucherfinder.app

# Supabase — used by server-side admin routes (health, sync)
# Must match the root app's SUPABASE_URL (from Supabase Dashboard → Settings → API)
# Server-side only (not exposed to browser). Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct DB connection for migration scripts (pg-based scripts in src/scripts/)
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string
# SUPABASE_DB_PASSWORD=your-db-password-here
# DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Internal API base (not accessible from the browser — rewrites via Next.js)
# Local dev (standalone): http://localhost:3000
# Docker / local backend: http://host.docker.internal:3001
# Production: http://backend:3001  (or internal IP/hostname of your backend service)
NEXT_PUBLIC_INTERNAL_API_URL=http://localhost:3000

# Private (server-side only) version of the above — used by API routes and
# internalApiClient.ts. In Vercel standalone, this points to the Railway/Render
# backend. NEVER expose this to the browser.
INTERNAL_API_URL=http://localhost:3000

# Google Search Console meta tag verification (optional)
# Leave empty to disable. Set value to your GSC verification string.
# NEXT_PUBLIC_GSC_VERIFY=google123abc...
NEXT_PUBLIC_GSC_VERIFY=

# ------------------------------------------------------------------
# 2. PRIVATE — server-side only, never exposed to the browser
# ------------------------------------------------------------------

# Session signing secret — must be a long random string (min 32 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_to_a_long_random_string

# Session version — increment to invalidate ALL sessions globally
# (e.g. after a security incident or credential rotation)
SESSION_VERSION=1

# Admin-to-control-plane authentication secret (used by /api/admin/proxy)
# Minimum 16 characters. Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CONTROL_PLANE_INTERNAL_SECRET=CHANGE_ME_to_a_long_random_string

# Admin credentials — bcrypt-hashed password for the admin login form
# Default admin: admin / CHANGE_ME_admin_password
# To generate a new hash:
#   node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_PASSWORD_HASH=$2a$10$your_hash_here

# ------------------------------------------------------------------
# 3. OPTIONAL — only needed for specific hosting / features
# ------------------------------------------------------------------

# ── Analytics ───────────────────────────────────────────────────────────────
# Analytics is DISABLED by default. Set NEXT_PUBLIC_ANALYTICS_ENABLED=true to enable.
# Supported providers: ga4, umami (default: ga4)
#
# GA4 setup:
#   1. Create GA4 property at analytics.google.com
#   2. Copy Measurement ID (G-XXXXXXXXXX)
#   3. Set NEXT_PUBLIC_GA4_MEASUREMENT_ID below
#
# Umami setup (self-hosted, GDPR-friendly):
#   1. Deploy at umami.is or use umami.is cloud
#   2. Copy website UUID from Umami dashboard
#   3. Set NEXT_PUBLIC_ANALYTICS_PROVIDER=umami
#   4. Set NEXT_PUBLIC_UMAMI_WEBSITE_ID and NEXT_PUBLIC_UMAMI_SCRIPT_URL
#
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=ga4
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://umami.is/script.js

# ── Redis / Async Jobs ──────────────────────────────────────────────────────
# Upstash Redis for async job queues (optional, for async voucher resolution)
# Format: redis://default:YOUR_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379
# Leave empty to disable async resolution (sync-only mode).
# UPSTASH_REDIS_URL=

# Rate limiting — leave empty to disable (suitable for low-traffic self-hosting)
# Format: UPSTASH_RATE_LIMIT_TOKEN=...  (from upstash.com)
# UPSTASH_RATE_LIMIT_TOKEN=

# ── AccessTrade Affiliate API ────────────────────────────────────────────────
# AccessTrade Vietnam affiliate network integration.
# Docs: https://docs.accesstrade.vn/
#
# ACCESSTRADE_API_KEY: Your AccessTrade API token (found in your AccessTrade dashboard)
# ACCESSTRADE_API_URL: Optional. Defaults to https://api.accesstrade.vn
#                       Change only if using a regional endpoint or self-hosted proxy.
#
# To test: GET /api/admin/accesstrade/test  (requires admin login)
# For full sync + Supabase ingestion, use the root package scripts:
#   npm run accesstrade:sync    (live sync)
#   npm run accesstrade:sync:dry (dry run)
#   npm run accesstrade:health   (connection check)
#
ACCESSTRADE_API_KEY=your_accesstrade_api_key_here
ACCESSTRADE_API_URL=https://api.accesstrade.vn

# MasOffer Publisher API
# MASOFFER_API_TOKEN: Your MasOffer API token (server-side secret — never expose to browser)
# MASOFFER_PUBLISHER_ID: Your MasOffer Publisher ID
# MASOFFER_API_URL: Optional. Defaults to https://publisher-api.masoffer.net
MASOFFER_PUBLISHER_ID=your_masoffer_publisher_id_here
MASOFFER_API_TOKEN=your_masoffer_api_token_here
# MASOFFER_API_URL=https://publisher-api.masoffer.net

# ── Ecomobi Publisher API ──────────────────────────────────────────────────────
# PENDING: Ecomobi integration scaffold. Replace with real credentials once
# Ecomobi API documentation and/or account access is available.
#
# Expected fields (TBD based on Ecomobi API docs):
#   ECOMOBI_API_KEY:       Bearer token for Ecomobi Publisher API
#   ECOMOBI_PUBLISHER_ID: Your Ecomobi Publisher ID (found in Ecomobi dashboard)
#   ECOMOBI_BASE_URL:     API base URL (default: https://api.ecomobi.com — TBD)
#
# Status: SCAFFOLD ONLY — not production-ready. See ECOMOBI_INTEGRATION_SCAFFOLD.md
ECOMOBI_PUBLISHER_ID=your_ecomobi_publisher_id_here
ECOMOBI_API_KEY=your_ecomobi_api_key_here
# ECOMOBI_BASE_URL=https://api.ecomobi.com

# ── AI Content Formatting ───────────────────────────────────────────────────
# Groq API key for AI content formatting in the blog editor.
# Free tier: https://console.groq.com — fast, no credit card needed.
# Only used server-side. Never expose to browser.
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── GitHub Actions Sync Scheduler ─────────────────────────────────────────────
# Required for the GitHub Actions sync-scheduler.yml workflow to call the sync
# endpoints securely. Both must be set as GitHub Secrets (NOT in this file).
#
# SYNC_SHARED_SECRET: shared secret used in x-sync-secret header (≥ 32 random chars)
# SYNC_ENDPOINT_URL:  full URL of your deployed sync endpoint, e.g.
#   https://your-railway-app.up.railway.app
#
# To generate SYNC_SHARED_SECRET:
#   openssl rand -hex 32
#
# In Vercel/Railway: set both as private environment variables.
# In GitHub: set as Secrets: SYNC_SHARED_SECRET and SYNC_ENDPOINT_URL.
# The sync endpoints are /api/internal/sync/daily and /api/internal/sync/health.
# These routes require the x-sync-secret header to be valid.
#
# SYNC_SHARED_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# SYNC_ENDPOINT_URL=https://your-railway-app.up.railway.app

# ============================================
# Affiliate Automation System - .gitignore
# ============================================

# Duplicate / nested copy — must NOT be committed
Affiliate/

# ----------------------------------------
# Node.js / Package Manager
# ----------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ----------------------------------------
# Build Output
# ----------------------------------------
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo
*.js.map

# ----------------------------------------
# Environment / Secrets
# ----------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local
.env.*.secret
!.env.example

# Per-app env files (apps/* has its own .env handling)
apps/*/.env
apps/*/.env.local
apps/*/.env.development
apps/*/.env.production
apps/*/.env.*.local
apps/*/.env.*.secret

# ----------------------------------------
# Logs / Temp / Cache
# ----------------------------------------
logs/
*.log
npm-debug.log*
yarn-error.log*
tmp/
temp/
.cache/
.turbo/

# ----------------------------------------
# Playwright / Browser Data
# ----------------------------------------
# Playwright test output
test-results/
playwright-report/
playwright/.cache/

# Browser user data (contains session cookies, login state)
# IMPORTANT: Never commit browser profiles!
shopee-data/
playwright-browsers/
.playwright/
chromium/
firefox/
webkit/

# Browser extensions
*.crx
*.xpi

# ----------------------------------------
# Supabase (except migrations)
# ----------------------------------------
supabase/
supabase/functions/*/index.ts

# Allow migrations folder
!supabase/migrations/

# ----------------------------------------
# OS / Editor Junk
# ----------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/
.classpath

# Vim
*.swo
*.swp

# Emacs
*~
\#*\#
.\#*

# ----------------------------------------
# Testing
# ----------------------------------------
coverage/
.nyc_output/
test-results/
__pycache__/
*.pyc

# Jest
.jest/
jest-coverage/

# Vitest
.vitest/

# ----------------------------------------
# Misc
# ----------------------------------------
*.bak
*.backup
*.tmp
*.temp
*.orig
*.rej
.pnp
.pnp.js
